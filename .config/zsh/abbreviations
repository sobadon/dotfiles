abbr "code"="'/mnt/c/Program Files/Microsoft VS Code/bin/code' ."
abbr "exp"="/mnt/c/Windows/explorer.exe ."
abbr "ga"="git add"
abbr "gc"="git commit"
abbr "gd"="git diff"
abbr "gds"="git diff --staged"
abbr "gl"="git lg"
