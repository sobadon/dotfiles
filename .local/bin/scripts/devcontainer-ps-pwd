#!/usr/bin/env bash

set -e

info=$(podman ps -a --filter "label=devcontainer.local_folder=$(pwd)" --format "NAMES: {{.Names}}
CONTAINER ID: {{.ID}}
IMAGE: {{.Image}}
CREATED: {{.CreatedAt}}
STATUS: {{.Status}}")

if [ -n "$info" ]; then
  echo "$info"
else
  echo "No devcontainer containers found for $(pwd)"
fi
